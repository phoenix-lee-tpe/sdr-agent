# Server
PORT=7071
PUBLIC_BASE_URL=http://localhost:7071
ADAPTER_REQUIRE_API_KEY=false
ADAPTER_API_KEY=
ADAPTER_API_KEY_HEADER=x-api-key

# Backend mode: mock or live
SALESFORCE_MODE=mock

# Salesforce OAuth, used only when SALESFORCE_MODE=live
SALESFORCE_MY_DOMAIN_URL=https://your-domain.my.salesforce.com
SALESFORCE_CONSUMER_KEY=
SALESFORCE_CONSUMER_SECRET=
SALESFORCE_AGENT_ID=

# Salesforce Agent API settings, used only when SALESFORCE_MODE=live.
# Defaults target the current Agent API host/path.
SALESFORCE_API_HOST=https://api.salesforce.com
SALESFORCE_AGENT_SESSION_URL=
SALESFORCE_AGENT_MESSAGE_URL_TEMPLATE=
