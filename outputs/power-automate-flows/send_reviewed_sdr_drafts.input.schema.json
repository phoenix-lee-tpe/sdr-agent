{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "send_reviewed_sdr_drafts input",
  "type": "object",
  "required": ["drafts", "approvalText"],
  "properties": {
    "drafts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["draftId"],
        "properties": {
          "draftId": { "type": "string" },
          "leadId": { "type": "string" },
          "leadName": { "type": "string" },
          "company": { "type": "string" },
          "to": { "type": "string" },
          "subject": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "approvalText": { "type": "string" }
  },
  "additionalProperties": false
}
